# PLAYOFF — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real.

# Fase 2 — Spotify (Authorization Code Flow)
NUXT_SPOTIFY_CLIENT_ID=
NUXT_SPOTIFY_CLIENT_SECRET=
NUXT_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# Fase 2 — Last.fm (metadados/gêneros)
NUXT_LASTFM_API_KEY=
NUXT_LASTFM_SHARED_SECRET=

# Fase 3 — Banco
DATABASE_URL=
