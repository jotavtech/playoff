# PLAYOFF — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real.
#
# No Vercel: configure estas chaves em Project → Settings → Environment Variables.
# Use o prefixo NUXT_ para que o Nitro leia em RUNTIME (não embute no build).

# ── Spotify (Authorization Code Flow) ───────────────────────────────────────
NUXT_SPOTIFY_CLIENT_ID=
NUXT_SPOTIFY_CLIENT_SECRET=
# Local:
NUXT_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback
# Produção (Vercel): https://SEU-DOMINIO.vercel.app/auth/spotify/callback
# Adicione ESSA mesma URL em Spotify Dashboard → App → Redirect URIs.

# ── Last.fm (metadados/gêneros — opcional) ──────────────────────────────────
NUXT_LASTFM_API_KEY=
NUXT_LASTFM_SHARED_SECRET=

# ── Banco (Fase futura — opcional) ──────────────────────────────────────────
DATABASE_URL=
