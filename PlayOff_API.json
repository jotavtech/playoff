{
  "version": "1",
  "type": "collection",
  "name": "PlayOff API - Sistema de Votação Musical",
  "uid": "playoff-api-collection",
  "description": "Collection completa para testar todas as APIs do PlayOff - Sistema de votação musical com Padrão Observer",
  "items": [
    {
      "uid": "health-check",
      "type": "http-request", 
      "name": "1. Health Check - Status do Sistema",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/api/health",
        "headers": []
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().status).to.equal('OK');\nexpect(res.getBody().totalSongs).to.be.a('number');"
    },
    {
      "uid": "list-songs",
      "type": "http-request",
      "name": "2. Listar Músicas - Ordenadas por Votos",
      "request": {
        "method": "GET", 
        "url": "http://localhost:3000/api/songs",
        "headers": []
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().songs).to.be.an('array');\nexpected(res.getBody().totalSongs).to.be.a('number');"
    },
    {
      "uid": "vote-simple",
      "type": "http-request",
      "name": "3. Voto Simples - Adicionar 1 Voto",
      "request": {
        "method": "POST",
        "url": "http://localhost:3000/api/vote",
        "headers": [
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "type": "json",
          "raw": "{\n  \"songId\": \"audioslave-cochise\"\n}"
        }
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().success).to.equal(true);\nexpect(res.getBody().song.votes).to.be.a('number');"
    },
    {
      "uid": "super-vote",
      "type": "http-request", 
      "name": "4. Super Voto - Adicionar 3 Votos",
      "request": {
        "method": "POST",
        "url": "http://localhost:3000/api/super-vote",
        "headers": [
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "type": "json",
          "raw": "{\n  \"songId\": \"deftones-change\"\n}"
        }
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().success).to.equal(true);\nexpect(res.getBody().song.votes).to.be.a('number');"
    },
    {
      "uid": "add-song",
      "type": "http-request",
      "name": "5. Adicionar Nova Música",
      "request": {
        "method": "POST", 
        "url": "http://localhost:3000/api/add-song",
        "headers": [
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "type": "json",
          "raw": "{\n  \"id\": \"teste-musica-nova\",\n  \"title\": \"Teste Bruno\",\n  \"artist\": \"Bruno API Test\",\n  \"audioUrl\": \"https://example.com/audio.mp3\",\n  \"albumCover\": \"https://example.com/cover.jpg\",\n  \"album\": \"Collection Test\",\n  \"year\": 2024,\n  \"votes\": 0\n}"
        }
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().success).to.equal(true);\nexpect(res.getBody().message).to.include('adicionada');"
    },
    {
      "uid": "reset-votes",
      "type": "http-request",
      "name": "6. Reset de Votos - Zerar Sistema",
      "request": {
        "method": "POST",
        "url": "http://localhost:3000/api/reset-votes",
        "headers": []
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().success).to.equal(true);\nexpect(res.getBody().message).to.include('resetados');"
    },
    {
      "uid": "delete-song",
      "type": "http-request",
      "name": "7. Remover Música - Delete por ID",
      "request": {
        "method": "DELETE",
        "url": "http://localhost:3000/api/songs/teste-musica-nova",
        "headers": []
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().success).to.equal(true);"
    },
    {
      "uid": "vote-observer-test",
      "type": "http-request",
      "name": "8. Teste Observer - Múltiplos Votos",
      "request": {
        "method": "POST",
        "url": "http://localhost:3000/api/vote",
        "headers": [
          {
            "name": "Content-Type", 
            "value": "application/json"
          }
        ],
        "body": {
          "type": "json",
          "raw": "{\n  \"songId\": \"gorillaz-feel-good-inc\"\n}"
        }
      },
      "tests": "expect(res.getStatus()).to.equal(200);\nexpect(res.getBody().success).to.equal(true);\n// Verificar se mudança de liderança ativa Observer\nif (res.getBody().highestVoted.id === 'gorillaz-feel-good-inc') {\n  expect(res.getBody().currentPlaying.song.id).to.equal('gorillaz-feel-good-inc');\n}"
    }
  ],
  "environments": [
    {
      "uid": "local-env",
      "name": "Local Development",
      "variables": [
        {
          "name": "baseUrl",
          "value": "http://localhost:3000"
        },
        {
          "name": "apiPrefix", 
          "value": "/api"
        }
      ]
    }
  ],
  "settings": {
    "headers": [],
    "auth": {
      "type": "none"
    },
    "docs": {
      "enabled": true
    }
  }
} 